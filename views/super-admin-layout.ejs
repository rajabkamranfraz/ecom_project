<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SYSTEM ADMIN | <%= typeof title != "undefined" ? title : "FIGHTFIT" %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <style>
      .admin-sidebar {
        width: 280px;
        background: rgba(10, 10, 15, 0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-right: 1px solid var(--border-glass);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        white-space: nowrap;
        box-shadow: 10px 0 30px rgba(0,0,0,0.5);
        z-index: 10;
      }
      .admin-sidebar .brand {
        padding: 30px 20px;
        border-bottom: 1px solid var(--border-glass);
      }
      .nav-section a {
        display: block;
        padding: 18px 25px;
        color: var(--text-muted);
        font-weight: 600;
        font-size: 1.1rem;
        border-left: 3px solid transparent;
        transition: all 0.3s;
      }
      .nav-section a:hover, .nav-section a.active {
        background: rgba(0, 240, 255, 0.05);
        color: #fff;
        border-left: 3px solid var(--accent-cyan);
      }
      .nav-section .divider {
        height: 1px;
        background: var(--border-glass);
        margin: 15px 0;
      }
      .admin-header {
        background: rgba(5, 5, 8, 0.8);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-glass);
        padding: 20px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 5;
      }
      .admin-content {
        padding: 40px;
        flex-grow: 1;
        overflow-y: auto;
      }
    </style>
</head>
<body style="background-color: var(--bg-dark);">
    <div style="display: flex; height: 100vh; overflow: hidden;">
        <!-- Sidebar -->
        <div class="admin-sidebar">
            <div class="brand">
                <h2 class="mb-0 text-uppercase" style="font-weight: 900; letter-spacing: -1px; color: #fff;">FIGHTFIT</h2>
            </div>
            <div class="nav-section mt-3">
                <a href="/super-admin"><i class="fas fa-network-wired me-3" style="width: 20px;"></i> Network Hub</a>
                <a href="/super-admin/analytics"><i class="fas fa-project-diagram me-3" style="width: 20px;"></i> Data Center</a>
                <a href="/super-admin/products"><i class="fas fa-boxes me-3" style="width: 20px;"></i> Arsenal Inventory</a>
                <a href="/super-admin/orders"><i class="fas fa-exchange-alt me-3" style="width: 20px;"></i> Transfers</a>
                <div class="divider"></div>
                <a href="/"><i class="fas fa-globe me-3" style="width: 20px;"></i> Return to Grid</a>
                <a href="/logout" style="color: var(--accent-pink);"><i class="fas fa-sign-out-alt me-3" style="width: 20px;"></i> Terminate Session</a>
            </div>
        </div>

        <!-- Main -->
        <div style="flex-grow: 1; display: flex; flex-direction: column; position: relative;">
            <!-- Background element -->
            <div style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle at 50% 50%, rgba(112,0,255,0.05) 0%, transparent 60%); z-index: -1; pointer-events: none;"></div>

            <div class="admin-header">
                <h4 class="m-0 text-white" style="text-transform: uppercase; letter-spacing: 1px;"><%= typeof title != "undefined" ? title : "DASHBOARD" %></h4>
                <div class="d-flex align-items-center gap-3">
                    <span class="fw-bold fs-6 text-muted"><i class="fas fa-user-shield me-2" style="color: var(--accent-cyan);"></i> <%= user ? user.name : 'ADMIN' %></span>
                </div>
            </div>
            <div class="admin-content" id="adminScroll">
                <% if(typeof(flash)!="undefined") { %>
                  <div id="adminFlashAlert" class="p-3 mb-4 fw-bold text-white border-0 card-glass" style="background: rgba(0,240,255,0.1); border-left: 4px solid var(--accent-cyan) !important; transition: opacity 0.5s ease-out, transform 0.5s ease-out;">
                    <i class="fas fa-info-circle me-2" style="color: var(--accent-cyan);"></i> <%= flash.message %>
                  </div>
                  <script>
                    setTimeout(() => {
                      const alertBox = document.getElementById('adminFlashAlert');
                      if(alertBox) {
                        alertBox.style.opacity = '0';
                        alertBox.style.transform = 'translateY(-20px)';
                        setTimeout(() => alertBox.remove(), 500);
                      }
                    }, 3500);
                  </script>
                <% } %>
                <%- body %>
            </div>
        </div>
    </div>

    <!-- Scroll Reveal Logic -->
    <script>
      function revealAdmin() {
        var reveals = document.querySelectorAll(".reveal");
        for (var i = 0; i < reveals.length; i++) {
          var windowHeight = window.innerHeight;
          var elementTop = reveals[i].getBoundingClientRect().top;
          var elementVisible = 50;
          if (elementTop < windowHeight - elementVisible) {
            reveals[i].classList.add("active");
          }
        }
      }
      document.getElementById('adminScroll').addEventListener("scroll", revealAdmin);
      setTimeout(revealAdmin, 100);
    </script>
    <style>
      .pulse-glow { animation: pulseGlow 2s infinite; }
      @keyframes pulseGlow {
        0% { box-shadow: 0 0 0 0 rgba(0, 240, 255, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(0, 240, 255, 0); }
        100% { box-shadow: 0 0 0 0 rgba(0, 240, 255, 0); }
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <%- include("./super-admin/partials/admin-chatbot") %>
</body>
</html>
