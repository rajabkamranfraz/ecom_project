<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FightFit — Advanced Combat Sports Platform" />
    <title>FIGHTFIT | <%= typeof pagetitle !== 'undefined' ? pagetitle : "STORE" %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js for analytics -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <!-- Live Toolbar -->
    <div class="live-toolbar">
      <a href="/shop" title="Shop Gear"><i class="fas fa-shopping-bag"></i></a>
      <a href="/trainers" title="Trainers"><i class="fas fa-dumbbell"></i></a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/my-account" title="Account"><i class="fas fa-user-circle"></i></a>
      <% } else { %>
        <a href="/login" title="Login"><i class="fas fa-sign-in-alt"></i></a>
      <% } %>
    </div>

    <%- include("./partials/header") %>

    <% if(typeof(flash)!="undefined") { %>
      <div id="flashAlert" class="container" style="margin-top: 100px; position: relative; z-index: 50; transition: opacity 0.5s ease-out, transform 0.5s ease-out;">
        <div class="alert alert-<%= flash.type %> card-glass text-center border-0" style="background: rgba(255,255,255,0.1); color: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
          <%= flash.message %>
        </div>
      </div>
      <script>
        setTimeout(() => {
          const fAlert = document.getElementById('flashAlert');
          if (fAlert) {
            fAlert.style.opacity = '0';
            fAlert.style.transform = 'translateY(-20px)';
            setTimeout(() => fAlert.remove(), 500);
          }
        }, 3500);
      </script>
    <% } %>

    <div class="body-content">
      <%- body %>
    </div>

    <footer class="mt-5 pt-5 pb-4" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(20px); border-top: 1px solid rgba(255,255,255,0.05);">
      <div class="container text-center">
        <h2 style="background: linear-gradient(to right, #fff, var(--accent-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">FIGHTFIT</h2>
        <div class="d-flex justify-content-center gap-4 my-4">
          <a href="#" class="fs-4" style="color: var(--text-muted);"><i class="fab fa-facebook-f"></i></a>
          <a href="#" class="fs-4" style="color: var(--text-muted);"><i class="fab fa-instagram"></i></a>
          <a href="#" class="fs-4" style="color: var(--text-muted);"><i class="fab fa-twitter"></i></a>
        </div>
        <p class="text-uppercase m-0" style="letter-spacing: 2px; font-size: 0.8rem; color: var(--text-muted);">&copy; 2026 FIGHTFIT PLATFORM. NEXT GEN ECOMMERCE.</p>
      </div>
    </footer>

    <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
      <%- include("./super-admin/partials/admin-chatbot") %>
    <% } else { %>
      <%- include("./layouts/partials/chatbot") %>
    <% } %>

    <!-- Scroll Reveal Logic -->
    <script>
      function reveal() {
        var reveals = document.querySelectorAll(".reveal");
        for (var i = 0; i < reveals.length; i++) {
          var windowHeight = window.innerHeight;
          var elementTop = reveals[i].getBoundingClientRect().top;
          var elementVisible = 100;
          if (elementTop < windowHeight - elementVisible) {
            reveals[i].classList.add("active");
          }
        }
      }
      window.addEventListener("scroll", reveal);
      reveal(); // Trigger on load
    </script>
  </body>
</html>