<script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.0/vanilla-tilt.min.js"></script>
<script>
  // 2. Typewriter Effect
  const words = ["PERFORMANCE", "EXECUTION", "DOMINANCE"];
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typewriter = document.getElementById("typewriter");

  function typeEffect() {
    const currentWord = words[wordIndex];
    if (isDeleting) {
      typewriter.textContent = currentWord.substring(0, charIndex - 1);
      charIndex--;
    } else {
      typewriter.textContent = currentWord.substring(0, charIndex + 1);
      charIndex++;
    }

    let typeSpeed = isDeleting ? 50 : 150;

    if (!isDeleting && charIndex === currentWord.length) {
      typeSpeed = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
      typeSpeed = 500;
    }

    setTimeout(typeEffect, typeSpeed);
  }
  setTimeout(typeEffect, 1000);

  // 3. Live Updating Chart
  const ctx = document.getElementById('homepageChart').getContext('2d');

  // Neon Green Gradient
  let gradient = ctx.createLinearGradient(0, 0, 0, 300);
  gradient.addColorStop(0, 'rgba(204, 255, 0, 0.4)');
  gradient.addColorStop(1, 'rgba(204, 255, 0, 0.0)');

  const chartData = [45, 52, 38, 65, 59, 80, 72];
  const homeChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['T-6', 'T-5', 'T-4', 'T-3', 'T-2', 'T-1', 'NOW'],
      datasets: [{
        label: 'Output Rate',
        data: chartData,
        borderColor: '#ccff00',
        backgroundColor: gradient,
        borderWidth: 3,
        fill: true,
        tension: 0.1, // jagged tech look
        pointBackgroundColor: '#000',
        pointBorderColor: '#ccff00',
        pointBorderWidth: 2,
        pointRadius: 5,
        pointHoverRadius: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          display: true,
          grid: { color: 'rgba(255,255,255,0.1)', drawBorder: false },
          ticks: { color: '#666', font: { family: 'monospace' } }
        },
        x: {
          grid: { color: 'rgba(255,255,255,0.1)', drawBorder: false },
          ticks: { color: '#666', font: { family: 'monospace' } }
        }
      },
      animation: { duration: 0 } // handled manually
    }
  });

  // Simulate real-time data push
  setInterval(() => {
    const el = document.getElementById('liveBlinker');
    el.style.opacity = el.style.opacity === '0' ? '1' : '0';

    // Every 2 seconds update chart data slightly
    if (Math.random() > 0.5) {
      let val = chartData[6] + (Math.floor(Math.random() * 20) - 10);
      if (val < 10) val = 10;
      if (val > 100) val = 100;
      chartData.shift();
      chartData.push(val);
      homeChart.update();
    }
  }, 1000);

  // 4. Counter Animation on Scroll
  let counted = false;
  window.addEventListener('scroll', function () {
    const oTop = document.getElementById('stat1').getBoundingClientRect().top;
    if (!counted && window.innerHeight > oTop) {
      animateValue("stat1", 0, 10450, 2000, "+");
      animateValue("stat2", 0, 99, 2000, "%");
      counted = true;
    }
  });

  function animateValue(id, start, end, duration, suffix) {
    let current = start;
    const range = end - start;
    const increment = end > start ? Math.ceil(range / 60) : -1;
    const stepTime = Math.abs(Math.floor(duration / 60));
    const obj = document.getElementById(id);
    const timer = setInterval(function () {
      current += increment;
      if (current >= end) {
        current = end;
        clearInterval(timer);
      }
      obj.innerHTML = (current > 1000 ? (current / 1000).toFixed(1) + 'K' : current) + suffix;
    }, stepTime);
  }
</script>

