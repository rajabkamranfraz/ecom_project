<div class="container" style="margin-top: 100px; padding-bottom: 100px;">
  <div class="row g-5">
    <!-- Sidebar Filters -->
    <div class="col-lg-3 reveal">
      <div class="card-glass p-4 position-sticky" style="top: 100px;">
        <h4 class="mb-4 text-white" style="text-shadow: 0 0 10px var(--accent-cyan);">MATRIX FILTERS</h4>
        <form action="/shop" method="GET">
          <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Data Node</label>
          <select name="category" class="form-select form-glass mb-4">
            <option value="" class="text-dark">All Protocols</option>
            <option value="gloves" class="text-dark" <%= currentFilters.category === 'gloves' ? 'selected' : '' %>>Gloves</option>
            <option value="equipment" class="text-dark" <%= currentFilters.category === 'equipment' ? 'selected' : '' %>>Equipment</option>
            <option value="uniforms" class="text-dark" <%= currentFilters.category === 'uniforms' ? 'selected' : '' %>>Uniforms</option>
          </select>

          <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Credit Limits</label>
          <div class="d-flex gap-2 mb-4">
            <input type="number" name="minPrice" placeholder="MIN" class="form-control form-glass" value="<%= currentFilters.minPrice %>">
            <input type="number" name="maxPrice" placeholder="MAX" class="form-control form-glass" value="<%= currentFilters.maxPrice %>">
          </div>

          <button type="submit" class="btn btn-modern w-100 mb-3">APPLY FILTERS</button>
          <a href="/shop" class="btn btn-outline-modern w-100 text-center" style="display:block;">RESET GRID</a>
        </form>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-end mb-5 pb-3 reveal" style="border-bottom: 1px solid var(--border-glass);">
        <h1 class="m-0" style="color: #fff;">GEAR <span style="color: var(--accent-cyan);">GRID</span></h1>
        <span class="badge-glow badge-purple"><%= products.length %> ITEMS ONLINE</span>
      </div>

      <div class="row g-5">
        <% if (products && products.length > 0) { %>
          <% products.forEach(function(product, i) { %>
            <div class="col-lg-4 col-md-6 reveal" style="transition-delay: <%= i * 0.1 %>s;">
              <div class="product-card h-100 d-flex flex-column">
                <a href="/product/<%= product.slug || product._id %>" class="product-img-wrapper">
                  <img src="<%= product.image ? product.image : 'https://dummyimage.com/400x400/111/e63946.png&text='+product.name %>" alt="<%= product.name %>" class="product-img">
                  <% if (product.stock <= 5 && product.stock > 0) { %>
                    <span class="product-badge text-warning">LOW STOCK</span>
                  <% } else if (product.stock === 0) { %>
                    <span class="product-badge text-danger" style="background: rgba(255,0,0,0.2);">DEPLETED</span>
                  <% } %>
                </a>
                <div class="product-info d-flex flex-column flex-grow-1">
                  <a href="/product/<%= product.slug || product._id %>" class="text-decoration-none">
                    <h5 class="product-title"><%= product.name %></h5>
                  </a>
                  <div class="product-price">$<%= parseFloat(product.price).toFixed(2) %></div>
                  <div class="mt-auto">
                    <% if (typeof user === 'undefined' || !user || user.role !== 'admin') { %>
                      <a href="/add-cart/<%= product._id %>" class="btn-acquire w-100"><i class="fas fa-shopping-cart me-2"></i> ACQUIRE</a>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="col-12 reveal">
            <div class="card-glass text-center p-5">
              <i class="fas fa-search-minus mb-4" style="font-size: 5rem; color: var(--text-muted);"></i>
              <h2 class="text-white">NO SIGNAL FOUND</h2>
              <p class="fs-5 text-muted">Adjust matrix filters to locate gear.</p>
            </div>
          </div>
        <% } %>
      </div>

      <% if (totalPages > 1) { %>
        <nav class="mt-5 pt-5 reveal" style="border-top: 1px solid var(--border-glass);">
          <ul class="pagination justify-content-center m-0">
            <% for(let i=1; i<=totalPages; i++) { %>
              <li class="page-item <%= page == i ? 'active' : '' %>" style="margin: 0 5px;">
                <a class="page-link" style="background: <%= page == i ? 'var(--accent-cyan)' : 'var(--bg-glass)' %>; color: <%= page == i ? '#000' : 'var(--text-main)' %>; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; font-weight: bold;" href="/shop/<%= i %>?category=<%= currentFilters.category %>&minPrice=<%= currentFilters.minPrice %>&maxPrice=<%= currentFilters.maxPrice %>"><%= i %></a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>
    </div>
  </div>
</div>

<style>
  /* Premium GenZ Product Card */
  .product-card {
    background: #050505;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(204, 255, 0, 0.3);
    box-shadow: 0 15px 35px rgba(0,0,0,0.6), 0 0 20px rgba(204, 255, 0, 0.05);
  }

  .product-img-wrapper {
    width: 100%;
    height: 300px;
    overflow: hidden;
    display: block;
    position: relative;
    background: #fff; /* Pure background for product shots to pop cleanly */
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Contain to show full product without cutting off */
    padding: 20px;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    mix-blend-mode: multiply; /* Blends white background naturally */
  }

  .product-card:hover .product-img {
    transform: scale(1.08);
  }

  .product-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 5px 12px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 1px;
    border-radius: 6px;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .product-info {
    padding: 25px;
    background: #0a0a0a;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .product-title {
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 8px;
    transition: color 0.3s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-card:hover .product-title {
    color: var(--accent-cyan);
  }

  .product-price {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-muted);
    margin-bottom: 25px;
    font-family: monospace;
  }

  .btn-acquire {
    display: inline-block;
    text-align: center;
    padding: 12px;
    background: #111;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    font-weight: 800;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s;
  }

  .btn-acquire:hover {
    background: var(--accent-cyan);
    color: #000;
    border-color: var(--accent-cyan);
    box-shadow: 0 0 15px rgba(204, 255, 0, 0.4);
  }
</style>
