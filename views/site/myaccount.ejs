<div class="container" style="margin-top: 100px; padding-bottom: 100px;">
  <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom border-glass reveal">
    <div>
      <h1 class="m-0 text-white">OPERATOR <span style="color: var(--accent-cyan);">DASHBOARD</span></h1>
      <p class="fs-6 text-muted text-uppercase letter-spacing-2 m-0 mt-2">ID: <%= user.name %> // STATUS: ONLINE</p>
    </div>
    <div class="badge-glow badge-purple">LEVEL: <%= user.role.toUpperCase() %></div>
  </div>

  <div class="row g-5">
    <!-- Sidebar -->
    <div class="col-md-3 reveal" style="transition-delay: 0.1s;">
      <div class="card-glass p-3 sticky-top" style="top: 100px;">
        <div class="nav flex-column nav-pills custom-pills">
          <a href="#orders" class="nav-link active" data-bs-toggle="pill"><i class="fas fa-history me-3"></i> Sync Logs</a>
          <a href="#memberships" class="nav-link" data-bs-toggle="pill"><i class="fas fa-id-badge me-3"></i> Clearance</a>
          <a href="#bookings" class="nav-link" data-bs-toggle="pill"><i class="fas fa-calendar-check me-3"></i> Sessions</a>
          <a href="#profile" class="nav-link" data-bs-toggle="pill"><i class="fas fa-user-cog me-3"></i> Config</a>
          <div style="height: 1px; background: var(--border-glass); margin: 15px 0;"></div>
          <a href="/logout" class="nav-link text-danger-custom"><i class="fas fa-power-off me-3"></i> Disconnect</a>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="col-md-9 reveal" style="transition-delay: 0.2s;">
      <div class="tab-content card-glass p-5" style="min-height: 500px;">

        <!-- Orders -->
        <div class="tab-pane fade show active" id="orders">
          <h4 class="mb-4 text-white"><i class="fas fa-history me-2" style="color: var(--accent-cyan);"></i> ACQUISITION LOGS</h4>
          <% if(orders && orders.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-glass align-middle m-0">
                <thead><tr><th>HASH ID</th><th>TIMESTAMP</th><th>VALUE</th><th>STATUS</th></tr></thead>
                <tbody>
                  <% orders.forEach(order => { %>
                    <tr>
                      <td class="text-muted" style="font-family: monospace;">#<%= order._id.toString().slice(-8) %></td>
                      <td class="text-white"><%= new Date(order.createdAt).toLocaleDateString() %></td>
                      <td class="fw-bold" style="color: var(--accent-cyan);">$<%= order.total_amount.toFixed(2) %></td>
                      <td>
                        <% if(order.status.toLowerCase() === 'delivered') { %>
                          <span class="badge-glow badge-cyan">DELIVERED</span>
                        <% } else { %>
                          <span class="badge-glow badge-purple"><%= order.status.toUpperCase() %></span>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="fas fa-folder-open mb-4" style="font-size: 4rem; color: rgba(255,255,255,0.1);"></i>
              <h4 class="text-white">NO LOGS FOUND</h4>
              <p class="text-muted">Initiate a transfer to populate this database.</p>
              <a href="/shop" class="btn btn-outline-modern mt-3">BROWSE MATRIX</a>
            </div>
          <% } %>
        </div>

        <!-- Memberships -->
        <div class="tab-pane fade" id="memberships">
          <h4 class="mb-4 text-white"><i class="fas fa-id-badge me-2" style="color: var(--accent-purple);"></i> CLEARANCE STATUS</h4>
          <% if(typeof memberships !== 'undefined' && memberships && memberships.length > 0) { %>
            <div class="row g-4">
              <% memberships.forEach(m => { %>
                <div class="col-md-6">
                  <div class="card-glass p-4 text-center border-0" style="background: rgba(112,0,255,0.1); border-top: 3px solid var(--accent-purple) !important;">
                    <h4 class="text-white text-uppercase"><%= m.membership_id ? m.membership_id.name : 'PROTOCOL' %></h4>
                    <p class="text-muted mt-3 mb-4">VALID UNTIL: <span class="text-white fw-bold"><%= new Date(m.end_date).toLocaleDateString() %></span></p>
                    <span class="badge-glow badge-purple d-inline-block px-4 py-2">ACTIVE</span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="fas fa-ban mb-4" style="font-size: 4rem; color: rgba(255,255,255,0.1);"></i>
              <h4 class="text-white">RESTRICTED ACCESS</h4>
              <p class="text-muted">You do not hold any active training clearances.</p>
              <a href="/memberships" class="btn btn-modern mt-3">UPGRADE CLEARANCE</a>
            </div>
          <% } %>
        </div>

        <!-- Bookings -->
        <div class="tab-pane fade" id="bookings">
          <h4 class="mb-4 text-white"><i class="fas fa-calendar-check me-2" style="color: var(--accent-pink);"></i> SCHEDULED PROTOCOLS</h4>
          <% if(typeof bookings !== 'undefined' && bookings && bookings.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-glass align-middle m-0">
                <thead><tr><th>INSTRUCTOR NODE</th><th>TIMESTAMP</th><th>STATUS</th></tr></thead>
                <tbody>
                  <% bookings.forEach(b => { %>
                    <tr>
                      <td class="text-white fw-bold"><%= b.trainer_id ? b.trainer_id.name : 'UNASSIGNED' %></td>
                      <td class="text-muted"><%= new Date(b.date).toLocaleDateString() %></td>
                      <td><span class="badge-glow badge-pink">LOCKED</span></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="fas fa-calendar-times mb-4" style="font-size: 4rem; color: rgba(255,255,255,0.1);"></i>
              <h4 class="text-white">NO SESSIONS SCHEDULED</h4>
              <a href="/trainers" class="btn btn-outline-modern mt-3">FIND INSTRUCTOR</a>
            </div>
          <% } %>
        </div>

        <!-- Profile -->
        <div class="tab-pane fade" id="profile">
          <h4 class="mb-4 text-white"><i class="fas fa-user-cog me-2" style="color: var(--accent-cyan);"></i> CONFIGURATION</h4>
          <div class="mb-4">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Designation</label>
            <input type="text" class="form-control form-glass" value="<%= user.name %>" readonly style="opacity: 0.7;">
          </div>
          <div class="mb-4">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Commlink</label>
            <input type="email" class="form-control form-glass" value="<%= user.email %>" readonly style="opacity: 0.7;">
          </div>
          <div class="mb-0">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Security Level</label>
            <input type="text" class="form-control form-glass text-uppercase fw-bold" value="<%= user.role %>" readonly style="color: var(--accent-cyan); border-color: var(--accent-cyan); background: rgba(0,240,255,0.05);">
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
.custom-pills .nav-link {
  color: var(--text-muted);
  border-radius: 10px;
  padding: 12px 20px;
  margin-bottom: 5px;
  transition: all 0.3s;
  font-weight: 600;
}
.custom-pills .nav-link:hover {
  background: rgba(255,255,255,0.05);
  color: #fff;
}
.custom-pills .nav-link.active {
  background: rgba(0,240,255,0.1);
  color: var(--accent-cyan);
  border-left: 3px solid var(--accent-cyan);
  border-radius: 0 10px 10px 0;
}
.text-danger-custom {
  color: var(--accent-pink) !important;
}
.text-danger-custom:hover {
  background: rgba(255,0,127,0.1) !important;
}
</style>
