<div class="container" style="margin-top: 100px; padding-bottom: 120px;">
  <div class="row justify-content-center">
    <div class="col-md-6 reveal">
      <div class="card-glass p-5 text-center position-relative overflow-hidden">
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: var(--accent-purple); box-shadow: 0 0 20px var(--accent-purple);"></div>
        
        <i class="fas fa-fingerprint mb-4" style="font-size: 5rem; color: var(--accent-purple); text-shadow: 0 0 20px var(--accent-purple);"></i>
        
        <h2 class="text-white mb-2" style="font-size: 2rem; text-transform: uppercase;">INITIALIZING <span style="color: var(--accent-purple);"><%= tier.replace('Tier', ' TIER') %></span></h2>
        <p class="text-muted mb-5">Authentication required to bind this clearance level to your identity.</p>
        
        <div class="text-start mb-5 p-4 rounded" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1);">
          <h6 class="text-white mb-3" style="letter-spacing: 1px;"><i class="fas fa-shield-alt me-2" style="color: var(--accent-cyan);"></i> SECURITY PROTOCOLS</h6>
          <ul class="text-muted fs-6 m-0 ps-3" style="line-height: 1.8;">
            <li>Membership binds to your unique biometric ID.</li>
            <li>Billing cycles automatically renew every 30 days.</li>
            <li>Grid access is monitored strictly. Unauthorized distribution of neural links will result in immediate termination.</li>
          </ul>
        </div>
        
        <form action="/subscribe/<%= tier %>" method="POST">
          <div class="form-check text-start mb-4">
            <input class="form-check-input" type="checkbox" id="agree" required style="background-color: transparent; border-color: var(--accent-cyan);">
            <label class="form-check-label text-white ms-2" for="agree">
              I agree to the Terms of Matrix Engagement
            </label>
          </div>

          <button type="submit" class="btn btn-modern w-100 fs-5 py-3" style="background: transparent; border-color: var(--accent-purple); color: var(--accent-purple);"><i class="fas fa-bolt me-2"></i> AUTHORIZE CLEARANCE</button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .btn-modern[type="submit"]:hover {
    background: var(--accent-purple) !important;
    color: #fff !important;
    box-shadow: 0 0 20px rgba(187, 0, 255, 0.4) !important;
  }
</style>
