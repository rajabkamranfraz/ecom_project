<div class="container" style="margin-top: 100px; padding-bottom: 100px;">
  <div class="row justify-content-center">
    <div class="col-md-5 reveal">
      <div class="card-glass p-5 position-relative">
        <!-- Decorative glowing orbit -->
        <div style="position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; border-radius: 50%; border: 2px solid var(--accent-cyan); border-left-color: transparent; border-bottom-color: transparent; animation: spin 4s infinite linear; pointer-events: none;"></div>
        
        <div class="text-center mb-5">
          <h1 class="m-0" style="background: linear-gradient(to right, #fff, var(--accent-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">FIGHTFIT</h1>
          <p class="text-muted fw-bold m-0 letter-spacing-1 text-uppercase mt-2">Neural Authentication</p>
        </div>
        <form action="/login" method="POST">
          <div class="mb-4">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Identity Token (Email)</label>
            <input type="email" class="form-control form-glass fs-5" name="email" required placeholder="USER@NETWORK.COM">
          </div>
          <div class="mb-5">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Access Cipher (Password)</label>
            <input type="password" class="form-control form-glass fs-5" name="password" required>
          </div>
          <button type="submit" class="btn btn-modern w-100 fs-5 py-3">ESTABLISH CONNECTION</button>
        </form>
        <div class="mt-5 text-center pt-4" style="border-top: 1px solid var(--border-glass);">
          <span class="text-muted">New Operator?</span> <a href="/register" class="fw-bold ms-2" style="color: var(--accent-purple);">Request Clearance</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
@keyframes spin { 100% { transform: rotate(360deg); } }
</style>
