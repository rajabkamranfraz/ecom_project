<div class="container" style="margin-top: 100px; padding-bottom: 120px;">
  <div class="text-center mb-5 pb-5 border-bottom border-glass reveal">
    <h1 style="font-size: 4.5rem; background: linear-gradient(to right, #fff, var(--accent-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">SECURITY CLEARANCES</h1>
    <p class="fs-5 text-muted fw-bold">Select your access protocol to the physical training grid.</p>
  </div>

  <div class="row g-5 justify-content-center">
    <div class="col-md-4 reveal" style="transition-delay: 0.1s;">
      <div class="card-glass text-center p-5 h-100 d-flex flex-column">
        <h3 class="mb-4 text-white">BASIC TIER</h3>
        <div class="mb-5">
          <span style="font-size: 4rem; font-weight: 800; color: var(--text-muted);">$50</span>
          <span class="fs-5 text-muted">/MO</span>
        </div>
        <ul class="list-unstyled text-start mx-auto mb-5 fs-6 text-muted" style="max-width: 250px;">
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-cyan);"></i> Grid Access (0600-2200)</li>
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-cyan);"></i> 2 Group Simulations</li>
          <li class="mb-3" style="opacity: 0.4;"><i class="fas fa-times me-3"></i> No Direct Neural Uplink</li>
        </ul>
        <a href="/activate-membership/BasicTier" class="btn btn-outline-modern w-100 mt-auto">INITIALIZE</a>
      </div>
    </div>

    <div class="col-md-4 reveal" style="transition-delay: 0.2s;">
      <div class="card-glass text-center p-5 h-100 d-flex flex-column" style="transform: scale(1.05); z-index: 2; border-color: var(--accent-cyan); box-shadow: 0 0 30px rgba(0,240,255,0.15); background: rgba(0,240,255,0.02); overflow: visible;">
        <div class="badge-glow badge-cyan" style="position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: var(--bg-dark); white-space: nowrap; padding: 5px 15px; font-size: 0.85rem;">RECOMMENDED PROTOCOL</div>
        <h3 class="mb-4 mt-3 text-white">FIGHTER TIER</h3>
        <div class="mb-5">
          <span style="font-size: 4.5rem; font-weight: 800; color: var(--accent-cyan); text-shadow: var(--glow-cyan);">$90</span>
          <span class="fs-5 text-muted">/MO</span>
        </div>
        <ul class="list-unstyled text-start mx-auto mb-5 fs-6 text-white" style="max-width: 250px;">
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-cyan);"></i> 24/7 Grid Access</li>
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-cyan);"></i> Unlimited Simulations</li>
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-cyan);"></i> 1 Direct Neural Uplink</li>
        </ul>
        <a href="/activate-membership/FighterTier" class="btn btn-modern w-100 mt-auto">INITIALIZE</a>
      </div>
    </div>

    <div class="col-md-4 reveal" style="transition-delay: 0.3s;">
      <div class="card-glass text-center p-5 h-100 d-flex flex-column">
        <h3 class="mb-4 text-white">PRO TIER</h3>
        <div class="mb-5">
          <span style="font-size: 4rem; font-weight: 800; color: var(--accent-purple); text-shadow: var(--glow-purple);">$150</span>
          <span class="fs-5 text-muted">/MO</span>
        </div>
        <ul class="list-unstyled text-start mx-auto mb-5 fs-6 text-muted" style="max-width: 250px;">
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-purple);"></i> 24/7 Grid Access</li>
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-purple);"></i> Unlimited Simulations</li>
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-purple);"></i> 4 Direct Neural Uplinks</li>
          <li class="mb-3"><i class="fas fa-check me-3" style="color: var(--accent-purple);"></i> Secure Hardware Storage</li>
        </ul>
        <a href="/activate-membership/ProTier" class="btn btn-outline-modern w-100 mt-auto" style="border-color: var(--accent-purple); color: var(--accent-purple);">INITIALIZE</a>
      </div>
    </div>
  </div>
</div>
