<div class="container" style="margin-top: 100px; margin-bottom: 120px;">
  <div class="row justify-content-center">
    <div class="col-md-6 reveal">
      <div class="card-glass p-5 position-relative">
        <div style="position: absolute; bottom: -20px; left: -20px; width: 100px; height: 100px; border-radius: 50%; border: 2px solid var(--accent-purple); border-right-color: transparent; border-top-color: transparent; animation: spin-reverse 5s infinite linear; pointer-events: none;"></div>
        
        <div class="text-center mb-5">
          <h1 class="m-0" style="background: linear-gradient(to right, var(--accent-cyan), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">INITIALIZE NODE</h1>
          <p class="fs-5 text-muted m-0 mt-2">Establish new operator profile</p>
        </div>
        <form action="/register" method="POST">
          <div class="mb-4">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Operator Alias</label>
            <input type="text" class="form-control form-glass fs-5" name="name" required placeholder="J. DOE">
          </div>
          <div class="mb-4">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Commlink (Email)</label>
            <input type="email" class="form-control form-glass fs-5" name="email" required placeholder="USER@NETWORK.COM">
          </div>
          <div class="mb-4">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Secure Channel (Phone - Optional)</label>
            <input type="text" class="form-control form-glass fs-5" name="phone" placeholder="+1 234 567 8900">
          </div>
          <div class="mb-5">
            <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Access Cipher (Password)</label>
            <input type="password" class="form-control form-glass fs-5" name="password" required>
          </div>
          <button type="submit" class="btn btn-modern w-100 fs-5 py-3">AUTHORIZE CLEARANCE</button>
        </form>
        <div class="mt-5 text-center border-top pt-4" style="border-color: var(--border-glass) !important;">
          <span class="text-muted">Already registered?</span> <a href="/login" class="fw-bold ms-2" style="color: var(--accent-cyan);">Login Here</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
@keyframes spin-reverse { 100% { transform: rotate(-360deg); } }
</style>
