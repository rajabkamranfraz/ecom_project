<!-- GenZ Hacker / Tech Admin AI SEO Chatbot -->
<style>
    .admin-ai-bot {
        position: fixed;
        bottom: 40px;
        right: 40px;
        z-index: 1050;
    }

    /* The rotating radar trigger */
    .admin-ai-toggle {
        width: 70px;
        height: 70px;
        background: #000;
        color: var(--accent-cyan);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 30px;
        cursor: pointer;
        border-radius: 50%;
        box-shadow: 0 0 0 2px var(--accent-cyan), 0 0 20px rgba(204, 255, 0, 0.4);
        transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        position: relative;
        z-index: 1060;
    }
    .admin-ai-toggle::after {
        content: '';
        position: absolute;
        top: -5px; left: -5px; right: -5px; bottom: -5px;
        border-radius: 50%;
        border: 2px dashed var(--accent-cyan);
        animation: spinRotateAdmin 10s linear infinite;
    }
    .admin-ai-toggle:hover {
        transform: scale(1.1);
        background: var(--accent-cyan);
        color: #000;
        box-shadow: 0 0 0 2px #000, 0 0 30px rgba(204, 255, 0, 0.8);
    }
    @keyframes spinRotateAdmin { 100% { transform: rotate(360deg); } }

    /* The Sleek Terminal Panel */
    .admin-ai-window {
        position: fixed;
        bottom: 130px;
        right: 40px;
        width: 380px;
        background: rgba(5, 5, 5, 0.85);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 30px;
        display: none;
        flex-direction: column;
        z-index: 1050;
        overflow: hidden;
        transform-origin: bottom right;
        box-shadow: 0 30px 60px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.05);
        padding: 30px;
    }

    .admin-ai-window.active {
        display: flex;
        animation: slideUpFadeAdmin 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes slideUpFadeAdmin {
        0% { opacity: 0; transform: translateY(40px) scale(0.95); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Minimal Header */
    .admin-ai-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .admin-ai-header h3 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .admin-ai-header h3::before {
        content: '';
        display: block;
        width: 10px;
        height: 10px;
        background: var(--accent-cyan);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--accent-cyan);
        animation: pulseOrbAdmin 2s infinite;
    }

    @keyframes pulseOrbAdmin {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    /* Typography Description */
    .admin-ai-body {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex-grow: 1;
        overflow-y: auto;
        padding: 15px;
        max-height: 250px;
    }
    .admin-ai-body::-webkit-scrollbar { width: 0px; }

    .admin-msg-user, .admin-msg-bot {
        padding: 10px 15px;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: bold;
        line-height: 1.4;
        width: 85%;
        margin-bottom: 10px;
    }
    .admin-msg-user {
        background: rgba(255,255,255,0.05);
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 0;
    }
    .admin-msg-bot {
        background: rgba(204,255,0,0.1);
        color: var(--accent-cyan);
        border: 1px solid rgba(204,255,0,0.2);
        align-self: flex-start;
        border-bottom-left-radius: 0;
    }

    /* Massive GenZ Button / Input */
    .admin-input-area {
        padding: 15px;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        gap: 10px;
        background: rgba(0,0,0,0.5);
    }
    .admin-input-area input {
        flex-grow: 1;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 10px 15px;
        border-radius: 8px;
        color: #fff;
        font-weight: bold;
        outline: none;
    }
    .admin-input-area input:focus {
        border-color: var(--accent-cyan);
    }
    .admin-input-area button {
        background: var(--accent-cyan);
        color: #000;
        border: none;
        padding: 10px 15px;
        border-radius: 8px;
        font-weight: 900;
        cursor: pointer;
        transition: 0.3s;
    }
    .admin-input-area button:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px rgba(204,255,0,0.4);
    }

    .ai-admin-card {
        background: #000;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 12px;
        border-radius: 8px;
        margin-top: 10px;
    }
</style>

<div class="admin-ai-bot">
    <div class="admin-ai-window" id="adminAiWindow">
        <div class="admin-ai-header" style="padding: 20px;">
            <h3>FIGHTFIT ADMIN AI</h3>
            <i class="fas fa-compress-alt" style="cursor:pointer; color: rgba(255,255,255,0.3); font-size: 1.2rem; transition: 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.3)'" onclick="toggleAdminAi()"></i>
        </div>
        <div class="admin-ai-body" id="adminChatMessages">
            <div class="admin-msg-bot">
                Hello! I am FightFit Admin AI. How can I assist you with managing the platform today?
            </div>
        </div>
        <form class="admin-input-area" id="adminChatForm">
            <input type="text" id="adminChatInput" placeholder="Enter root command..." autocomplete="off">
            <button type="submit"><i class="fas fa-terminal"></i></button>
        </form>
    </div>
    <div class="admin-ai-toggle" onclick="toggleAdminAi()">
        <i class="fas fa-fingerprint"></i>
    </div>
</div>

<script>
function toggleAdminAi() {
    const win = document.getElementById('adminAiWindow');
    win.classList.toggle('active');
    if(win.classList.contains('active')) {
        setTimeout(() => document.getElementById('adminChatInput').focus(), 300);
    }
}

function appendAdminMsg(text, isUser=false) {
    const d = document.createElement('div');
    d.className = isUser ? 'admin-msg-user' : 'admin-msg-bot';
    d.innerHTML = text;
    document.getElementById('adminChatMessages').appendChild(d);
    const body = document.getElementById('adminChatMessages');
    body.scrollTop = body.scrollHeight;
}

document.getElementById('adminChatForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const input = document.getElementById('adminChatInput');
    const msg = input.value.trim();
    if(!msg) return;
    
    appendAdminMsg(msg, true);
    input.value = '';

    // If generating SEO natively from the Add/Edit form
    if(msg.toLowerCase().includes("generate seo")) {
        const nameInput = document.getElementById('productName');
        const deptInput = document.getElementById('department');
        const seoInput = document.getElementById('seoTags');
        const metaInput = document.getElementById('metaDetails');
        const descInput = document.getElementById('productDescription');
        
        if (!nameInput || !nameInput.value.trim()) {
            appendAdminMsg("<span style='color: #ff0055;'>ERROR: Form context missing. Navigate to 'Add/Edit Product' to use manual SEO injection.</span>");
            return;
        }
        
        appendAdminMsg("<i class='fas fa-circle-notch fa-spin'></i> UPLINKING TO AI KERNEL... GENERATING SEO & DESCRIPTION...");
        
        try {
            const response = await fetch('/super-admin/products/generate-seo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: nameInput.value.trim(), department: deptInput ? deptInput.value : 'General' })
            });
            const data = await response.json();
            if (response.ok && data) {
                if (data.seoTags && seoInput) seoInput.value = data.seoTags;
                if (data.metaDetails && metaInput) metaInput.value = data.metaDetails;
                if (data.description && descInput) descInput.value = data.description;
                appendAdminMsg("OVERRIDE SUCCESSFUL. SEO & Description injected.");
            } else {
                appendAdminMsg(`<span style='color: #ff0055;'>ERROR: ${data.error}</span>`);
            }
        } catch(err) {
            appendAdminMsg("<span style='color: #ff0055;'>CONNECTION SEVERED</span>");
        }
        return;
    }

    // Otherwise standard Admin Chat command
    appendAdminMsg("<i class='fas fa-circle-notch fa-spin'></i> PROCESSING...");
    try {
        const response = await fetch('/super-admin/products/chatbot/message', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: msg })
        });
        const data = await response.json();
        
        // Remove processing node
        const msgs = document.getElementById('adminChatMessages');
        msgs.removeChild(msgs.lastChild);
        
        appendAdminMsg(data.text);
    } catch(err) {
        appendAdminMsg("<span style='color: #ff0055;'>CONNECTION SEVERED</span>");
    }
});
</script>
