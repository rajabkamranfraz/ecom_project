<div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-glass pb-4 reveal">
    <div>
        <h2 class="m-0 text-white">TRANSFER <span style="color: var(--accent-cyan);">LOGS</span></h2>
        <p class="text-muted m-0 mt-2">Manage all active and completed combat asset requests.</p>
    </div>
</div>

<div class="card-glass p-0 reveal" style="transition-delay: 0.1s;">
    <div class="table-responsive custom-scrollbar">
        <table class="table table-glass align-middle mb-0">
            <thead>
                <tr>
                    <th class="p-4">Hash ID</th>
                    <th>Operator</th>
                    <th>Value</th>
                    <th>Timestamp</th>
                    <th>Status</th>
                    <th>Command Override</th>
                </tr>
            </thead>
            <tbody>
                <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td class="p-4 text-muted" style="font-family: monospace;">#<%= order._id.toString().slice(-8) %></td>
                            <td class="fw-bold text-white"><%= order.user_id ? order.user_id.name : 'GUEST' %></td>
                            <td class="fw-bold" style="color: var(--accent-cyan);">$<%= order.total_amount.toFixed(2) %></td>
                            <td class="text-muted"><%= new Date(order.createdAt).toLocaleDateString() %></td>
                            <td>
                                <% if(order.status.toLowerCase() === 'delivered') { %>
                                    <span class="badge-glow badge-cyan">DELIVERED</span>
                                <% } else { %>
                                    <span class="badge-glow badge-pink"><%= order.status.toUpperCase() %></span>
                                <% } %>
                            </td>
                            <td>
                                <form action="/super-admin/orders/update-status/<%= order._id %>" method="POST" class="d-flex gap-2">
                                    <select name="status" class="form-select form-glass py-1 px-2" style="max-width: 150px; font-size: 0.9rem; background-color: rgba(255,255,255,0.05); color: #fff;">
                                        <option value="Pending" style="background: #111; color: #fff;" <%= order.status==='Pending'?'selected':'' %>>Pending</option>
                                        <option value="Processing" style="background: #111; color: #fff;" <%= order.status==='Processing'?'selected':'' %>>Processing</option>
                                        <option value="Shipped" style="background: #111; color: #fff;" <%= order.status==='Shipped'?'selected':'' %>>Shipped</option>
                                        <option value="Delivered" style="background: #111; color: #fff;" <%= order.status==='Delivered'?'selected':'' %>>Delivered</option>
                                    </select>
                                    <button type="submit" class="btn btn-modern py-1 px-3" style="font-size: 0.8rem;">EXECUTE</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" class="text-center p-5 text-muted">NO LOGS DETECTED.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/admin-chatbot') %>
