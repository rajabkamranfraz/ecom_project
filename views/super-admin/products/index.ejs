<div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-glass pb-4 reveal">
    <div>
        <h2 class="m-0 text-white">ARSENAL <span style="color: var(--accent-cyan);">DATABASE</span></h2>
        <p class="text-muted m-0 mt-2">Manage deployable combat hardware.</p>
    </div>
    <a href="/super-admin/products/add" class="btn btn-modern fs-5"><i class="fas fa-plus me-2"></i> NEW ITEM</a>
</div>

<div class="mb-5 reveal">
    <div class="position-relative" style="max-width: 600px;">
        <i class="fas fa-search position-absolute text-muted" style="left: 20px; top: 50%; transform: translateY(-50%);"></i>
        <input type="text" class="form-control form-glass fs-5" id="productSearch" placeholder="SEARCH DATABASE..." style="padding-left: 50px; background: rgba(0,0,0,0.5);">
    </div>
</div>

<div class="card-glass p-0 reveal" style="transition-delay: 0.1s;">
    <div class="table-responsive custom-scrollbar">
        <table class="table table-glass align-middle mb-0">
            <thead>
                <tr>
                    <th class="p-4">Visual</th>
                    <th>Identifier</th>
                    <th>Value</th>
                    <th>Stock</th>
                    <th>SEO Matrix</th>
                    <th>Commands</th>
                </tr>
            </thead>
            <tbody id="productTableBody">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(product => { %>
                        <tr>
                            <td class="p-4">
                                <div style="width: 60px; height: 60px; background: rgba(0,0,0,0.5); border-radius: 8px; padding: 5px; border: 1px solid var(--border-glass);">
                                    <img src="<%= product.image || 'https://dummyimage.com/50x50/111/00f0ff' %>" style="width:100%;height:100%;object-fit:contain; filter: drop-shadow(0 0 5px rgba(0,240,255,0.3));">
                                </div>
                            </td>
                            <td class="fw-bold text-white"><%= product.name %></td>
                            <td class="fw-bold" style="color: var(--accent-cyan);">$<%= parseFloat(product.price).toFixed(2) %></td>
                            <td>
                                <% if(product.stock > 0){ %>
                                    <span class="badge-glow badge-cyan"><%= product.stock %> UNITS</span>
                                <% } else { %>
                                    <span class="badge-glow badge-pink">DEPLETED</span>
                                <% } %>
                            </td>
                            <td style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                <span class="text-muted" style="font-size: 0.9rem;"><%= product.seoTags || '—' %></span>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="/super-admin/products/edit/<%= product.slug || product._id %>" class="btn btn-sm btn-outline-modern" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/super-admin/products/delete/<%= product.slug || product._id %>" class="btn btn-sm btn-outline-modern" style="border-color: var(--accent-pink); color: var(--accent-pink);" onclick="return confirm('PERMANENTLY DELETE ASSET?');" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" class="text-center p-5 text-muted">DATABASE EMPTY. DEPLOY GEAR ABOVE.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
document.getElementById('productSearch').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('#productTableBody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});
</script>
