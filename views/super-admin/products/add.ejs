<div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-glass pb-4 reveal">
    <div>
        <h2 class="m-0 text-white">DEPLOY <span style="color: var(--accent-cyan);">ARSENAL</span></h2>
        <p class="text-muted m-0 mt-2">Initialize new combat hardware into the grid.</p>
    </div>
    <a href="/super-admin/products" class="btn btn-outline-modern fs-5"><i class="fas fa-arrow-left me-2"></i> ABORT</a>
</div>

<div class="card-glass p-5 reveal" style="transition-delay: 0.1s;">
    <form action="/super-admin/products/add" method="POST">
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Identifier</label>
                <input type="text" class="form-control form-glass fs-5" id="productName" name="name" required>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Value ($)</label>
                <input type="number" step="0.01" class="form-control form-glass fs-5" name="price" required>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Data Node</label>
                <select class="form-select form-glass fs-5" id="department" name="department" required style="background-color: rgba(255,255,255,0.05); color: #fff;">
                    <option value="GLOVES" style="background: #111; color: #fff;">GLOVES</option>
                    <option value="UNIFORMS" style="background: #111; color: #fff;">UNIFORMS</option>
                    <option value="EQUIPMENT" style="background: #111; color: #fff;">EQUIPMENT</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Initial Stock</label>
                <input type="number" class="form-control form-glass fs-5" name="stock" value="0" required>
            </div>
            <div class="col-md-9">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Visual Source (URL)</label>
                <input type="text" class="form-control form-glass fs-5" name="image">
            </div>
            <div class="col-md-12">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">System Logs (Description)</label>
                <textarea class="form-control form-glass fs-5" id="productDescription" name="description" rows="5"></textarea>
            </div>

            <div class="col-12 mt-5 mb-2 border-bottom border-glass pb-3">
                <h4 class="text-white m-0"><i class="fas fa-search me-2" style="color: var(--accent-cyan);"></i> SEO MATRIX</h4>
            </div>
            <div class="col-md-12">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">SEO Tags (comma separated)</label>
                <input type="text" class="form-control form-glass fs-5" id="seoTags" name="seoTags">
            </div>
            <div class="col-md-12">
                <label class="form-label text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 2px;">Meta Details / Tech Specs</label>
                <textarea class="form-control form-glass fs-5" id="metaDetails" name="metaDetails" rows="2"></textarea>
            </div>
            <div class="col-md-12 mt-5 text-end">
                <button type="submit" class="btn btn-modern fs-4 w-100 py-3"><i class="fas fa-upload me-2"></i> DEPLOY TO GRID</button>
            </div>
        </div>
    </form>
</div>

